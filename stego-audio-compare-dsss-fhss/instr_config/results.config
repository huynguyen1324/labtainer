# 1. Kiem tra tinh toan dung SNR cho DSSS
dsss_snr = snr_dsss.txt : CONTAINS : 20.

# 2. Kiem tra tinh toan dung SNR cho FHSS
fhss_snr = snr_fhss.txt : CONTAINS : 17.

# 3. Kiem tra giai ma dung DSSS tren kenh sach
dsss_clean = recovered_dsss.txt : CONTAINS : STGO

# 4. Kiem tra giai ma dung FHSS tren kenh sach
fhss_clean = recovered_fhss.txt : CONTAINS : STGO

# 5. Kiem tra FHSS khang nhieu don tan cuoc ep (Jamming) thanh cong
fhss_jam = recovered_fhss_jam.txt : CONTAINS : STGO
